/* Mutex protected UART print function */
void UART_Print(char *msg)
{
    if (xMutex != NULL)
    {
        if (xSemaphoreTake(xMutex, portMAX_DELAY) == pdTRUE)
        {
            HAL_UART_Transmit(&huart2,
                              (uint8_t *)msg,
                              strlen(msg),
                              HAL_MAX_DELAY);

            xSemaphoreGive(xMutex);
        }
    }
}

/* Objective 1: Two different tasks printing different messages */
void Print_Task1(void *argument)
{
    while (1)
    {
        UART_Print("Objective 1 - Task 1: Hello from first task\r\n");
        vTaskDelay(pdMS_TO_TICKS(1000));
    }
}

void Print_Task2(void *argument)
{
    while (1)
