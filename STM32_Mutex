int main(void)
{
    /* MCU Configuration--------------------------------------------------------*/

    HAL_Init();

    SystemClock_Config();

    MX_GPIO_Init();
    MX_USART2_UART_Init();

    /* USER CODE BEGIN 2 */

    char buffer[150];

    xMutex = xSemaphoreCreateMutex();

    sprintf(buffer, "\r\nMutex handle value = %p\r\n", (void *)xMutex);
    HAL_UART_Transmit(&huart2,
                      (uint8_t *)buffer,
                      strlen(buffer),
                      HAL_MAX_DELAY);

    if (xMutex != NULL)
    {
        HAL_UART_Transmit(&huart2,
                          (uint8_t *)"Mutex created successfully\r\n",
                          strlen("Mutex created successfully\r\n"),
                          HAL_MAX_DELAY);
    }
    else
    {
        HAL_UART_Transmit(&huart2,
                          (uint8_t *)"Mutex creation failed\r\n",
                          strlen("Mutex creation failed\r\n"),
                          HAL_MAX_DELAY);
    }

    /*
       Objective 1:
       Two different tasks print two different messages
       using the same shared UART printer.
    */
    xTaskCreate(Print_Task1,
                "PrintTask1",
                128,
                NULL,
                2,
                &PrintTask1Handle);

    xTaskCreate(Print_Task2,
                "PrintTask2",
                128,
                NULL,
                1,
                &PrintTask2Handle);

    /*
       Objective 3:
       Same priority tasks.
       Both tasks are assigned priority 2.
    */
    xTaskCreate(SamePriority_Task1,
                "SameTask1",
                128,
                NULL,
                2,
                &SameTask1Handle);

    xTaskCreate(SamePriority_Task2,
                "SameTask2",
                128,
                NULL,
                2,
                &SameTask2Handle);

    /*
       Objective 4:
       No delay tasks.
       These tasks are commented because they can continuously occupy the CPU.
       To test this objective, uncomment the two xTaskCreate() lines below.
       It is better to comment other task creation lines while testing no-delay tasks.
    */

    /*
    xTaskCreate(NoDelay_Task1,
                "NoDelay1",
                128,
                NULL,
                3,
                &NoDelayTask1Handle);

    xTaskCreate(NoDelay_Task2,
                "NoDelay2",
                128,
                NULL,
                1,
                &NoDelayTask2Handle);
    */

    /*
       Objective 5:
       Two LED blinking tasks with mutex protected UART printing.
       LED Task 1 has higher priority than LED Task 2.
    */
    xTaskCreate(LED_Task1,
                "LEDTask1",
                128,
                NULL,
                3,
                &LEDTask1Handle);

    xTaskCreate(LED_Task2,
                "LEDTask2",
                128,
                NULL,
                1,
                &LEDTask2Handle);

    vTaskStartScheduler();

    /* USER CODE END 2 */

    while (1)
    {
    }
}

