/* Objective 5: LED blinking tasks with critical section for printing */
void LED_Task1(void *argument)
{
    while (1)
    {
        HAL_GPIO_TogglePin(LD2_GPIO_Port, LD2_Pin);

        UART_Print("Objective 5 - LED Task 1: Printing inside critical section\r\n");

        vTaskDelay(pdMS_TO_TICKS(500));
    }
}

