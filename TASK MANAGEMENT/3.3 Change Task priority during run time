#include <Arduino_FreeRTOS.h>
#define LED1 6
TaskHandle_t Task1Handle;
void Task1(void *pvParameters)
{
  pinMode(LED1, OUTPUT);
  while (1)
  {
    digitalWrite(LED1, !digitalRead(LED1));
    Serial.print("TASK1 Priority = ");
    Serial.println(uxTaskPriorityGet(Task1Handle));
    vTaskDelay(1000 / portTICK_PERIOD_MS);
  }
}
void ControlTask(void *pvParameters)
{
  vTaskDelay(5000 / portTICK_PERIOD_MS);
  Serial.println("Changing TASK1 Priority to 4");
  // CHANGE PRIORITY DURING RUNTIME
  vTaskPrioritySet(Task1Handle, 4);
  while (1)
  {
    vTaskDelay(1000 / portTICK_PERIOD_MS);
  }
}

void setup()
{
  Serial.begin(9600);
  xTaskCreate(Task1, "Task1", 128, NULL, 1, &Task1Handle);
  xTaskCreate(ControlTask, "Control", 128, NULL, 2, NULL);
}
void loop()
{
}
